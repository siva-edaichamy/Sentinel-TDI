RANDOM_SEED=42
EMPLOYEE_COUNT=500
TIMELINE_DAYS=90
TIMELINE_START_DATE=2026-01-01

# Greenplum connection
GP_HOST=<your-greenplum-host>
GP_PORT=5432
GP_DB=<your-database>
GP_USER=<your-user>
GP_PASSWORD=<your-password>

# MinIO (S3-compatible object storage — must be reachable from GP segment hosts)
MINIO_ENDPOINT=http://<minio-host>:9000
MINIO_ACCESS_KEY=<your-minio-access-key>
MINIO_SECRET_KEY=<your-minio-secret-key>
MINIO_BUCKET=sentinel-bronze
MINIO_REGION=us-east-1

# Airflow DAG target (write-and-deliver only, not executed locally)
AIRFLOW_DAG_OWNER=airflow
