agents/agent1_bronze.py
agents/agent2_silver.py
agents/agent3_gold.py
agents/agent4_platform.py
agents/agent5_validation.py
agents/agent6_analytics.py

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
build/

# Airflow
logs/
airflow.db
airflow.cfg

